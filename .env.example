# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — required for Admin → Users tab (invite / remove admins)
# ⚠️  Never deploy this to a public URL. Internal/local use only.
# Get it from: Supabase Dashboard → Project Settings → API → service_role
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get these from: cloudinary.com → Dashboard
# Upload preset: Settings → Upload → Add upload preset → set to "Unsigned"
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=tft2-arena-uploads
